# ── EDGX Studio — Environment Variables ───────────────────────────────────

# YouTube Data API v3 — get from console.cloud.google.com
# Enable "YouTube Data API v3" then create an API key
YOUTUBE_API_KEY=AIza_your_key_here

# Groq (script generation)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs (TTS synthesis)
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_JANE_ID=EXAVITQu4vr4xnSDxMaL   # Replace with your Jane voice ID
ELEVENLABS_ALEX_ID=VR6AewLTigWG4xSOukaG   # Replace with your Alex voice ID

# Auth — same secret used in the dashboard Studio config
EDGX_API_SECRET=your_random_64_char_secret_here

# Email relay (optional — inherited from edgx-mailer)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=EDGX Jane <jane@yourdomain.com>
EMAIL_TO=you@yourdomain.com

# Railway sets PORT automatically
PORT=3001
